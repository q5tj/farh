{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm --filter @workspace/farah build:web",
  "outputDirectory": "dist",
  "installCommand": "pnpm install --frozen-lockfile=false",
  "framework": null,
  "trailingSlash": false,
  "cleanUrls": false,
  "rewrites": [
    {
      "source": "/((?!.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
